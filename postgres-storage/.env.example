# Postgres Storage TypeScript example — environment variables
# Copy to .env and fill in your values.

# LLM provider (pick one — required)
GEMINI_API_KEY=
#GROQ_API_KEY=
#ANTHROPIC_API_KEY=
#OPENAI_API_KEY=

# PostgreSQL
POSTGRES_PASSWORD=orchid
CHAT_DB_DSN=postgresql://orchid:orchid@postgres:5432/orchid

# Optional: API / auth defaults
AUTH_SECRET=dev-auth-secret-change-in-prod
MCP_TOKEN=demo-token
