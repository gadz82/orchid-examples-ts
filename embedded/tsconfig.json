{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "verbatimModuleSyntax": false,
        "noEmit": true,
        "lib": ["ES2022"],
        "types": ["node"]
    },
    "include": ["*.ts"]
}
