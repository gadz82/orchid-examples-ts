# Embedded TypeScript example — environment variables
# Copy to .env and fill in your values.

# LLM provider (pick one — required)
GEMINI_API_KEY=
#GROQ_API_KEY=
#ANTHROPIC_API_KEY=
#OPENAI_API_KEY=

# Qdrant vector database
QDRANT_URL=http://localhost:6333

# PostgreSQL
POSTGRES_PASSWORD=orchid
POSTGRES_URL=postgresql://orchid:orchid@localhost:5432/orchid

